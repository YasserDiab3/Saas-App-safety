# ============================================================
# HSE SaaS — Environment template. Copy to .env and fill in.
# NEVER commit the real .env (it is gitignored).
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Service role: server-side / Edge Functions ONLY — never ship to the browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- Stripe (Billing) ----
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
# Price IDs per plan (created in Stripe dashboard)
STRIPE_PRICE_PRO=price_XXXX
STRIPE_PRICE_ENTERPRISE=price_XXXX

# ---- App ----
APP_URL=https://app.example.com
DEFAULT_TRIAL_DAYS=14
