# ============================================================
# HSE SaaS — Environment template. Copy to .env and fill in.
# NEVER commit the real .env (it is gitignored).
# ============================================================

# ---- Supabase (optional here — auto-injected in Edge Functions) ----
SUPABASE_URL=https://tbkajjarkqhsdiabufjv.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Service role: Edge Functions ONLY — never ship to the browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- Stripe (Billing) — REQUIRED for set-stripe-secrets.ps1 ----
# Dashboard → Developers → API keys (Test mode first)
STRIPE_SECRET_KEY=sk_test_XXXX
# Not used by Edge Functions today; keep for future client-side Stripe.js
STRIPE_PUBLISHABLE_KEY=pk_test_XXXX
# Dashboard → Webhooks → signing secret for stripe-webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_XXXX
# Dashboard → Products → monthly subscription Price IDs
STRIPE_PRICE_PRO=price_XXXX
STRIPE_PRICE_ENTERPRISE=price_XXXX

# ---- App ----
# Your Vercel deployment URL (no trailing slash) — used for Checkout success/cancel URLs
APP_URL=https://your-app.vercel.app
DEFAULT_TRIAL_DAYS=14
