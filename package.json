{
  "name": "hse-saas",
  "private": true,
  "description": "HSEHub 360 — Vercel build entry (delegates to frontend/)",
  "scripts": {
    "build": "cd frontend && npm ci && npm run build",
    "setup-hooks": "node scripts/setup-git-hooks.mjs",
    "bump-version": "cd frontend && npm run bump-version",
    "verify-version": "cd frontend && npm run verify-version",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "wrangler": "^4.106.0"
  }
}
